{
  "model": {
    "name": "auto"
  },
  "permissions": {
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".gemini/hooks/session-end-handoff.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".gemini/hooks/session-sync.sh",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": ".gemini/hooks/target-cleanup.sh",
            "timeout": 60000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": ".gemini/hooks/pre-read-guard.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".gemini/hooks/block-large-writes.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".gemini/hooks/task-lock.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".gemini/hooks/protect-memory.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": ".gemini/hooks/enforce-lsp.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": ".gemini/hooks/block-mcp.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".gemini/hooks/block-direct-deploy.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".gemini/hooks/post-edit-dispatch.sh",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": ".gemini/hooks/context-pressure.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".gemini/hooks/knowledge-capture.sh",
            "timeout": 10000,
            "async": true
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".gemini/hooks/pre-compact-state.sh",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
